{
  "name": "@printr/cli",
  "version": "0.3.1",
  "description": "CLI for Printr - configure MCP servers and install agent skills",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "printr": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PrintrFi/printr-mcp",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "keywords": [
    "printr",
    "cli",
    "mcp",
    "ai",
    "agent",
    "skills",
    "solana",
    "evm",
    "token",
    "web3"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun run scripts/build.ts --watch",
    "start": "bun dist/index.js",
    "test": "echo 'No tests yet for CLI package'",
    "test:all": "echo 'No tests yet for CLI package'",
    "typecheck": "bun run --cwd ../sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@printr/sdk": "workspace:*",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
