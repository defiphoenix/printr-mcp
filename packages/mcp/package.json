{
  "name": "@printr/mcp",
  "version": "0.13.1",
  "description": "MCP server library for the Printr API - enables AI agents to launch tokens across EVM chains and Solana",
  "mcpName": "io.github.PrintrFi/printr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "printr-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "certs",
    "LICENSE",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PrintrFi/printr-mcp",
    "directory": "packages/mcp"
  },
  "license": "Apache-2.0",
  "keywords": [
    "printr",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "solana",
    "evm",
    "token",
    "web3",
    "crypto"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "test": "bun test src/",
    "test:all": "bun test",
    "test:e2e": "bun test src/e2e.spec.ts",
    "typecheck": "bun run --cwd ../sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@printr/sdk": "workspace:*",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "hono": "^4.12.9",
    "neverthrow": "^8.2.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "ts-pattern": "^5.9.0",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
