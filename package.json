{
  "name": "printr-monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrintrFi/printr-mcp"
  },
  "license": "Apache-2.0",
  "workspaces": ["packages/*", "examples/*"],
  "scripts": {
    "build": "bun run build:sdk && bun run build:packages",
    "build:sdk": "bun run --cwd packages/sdk build",
    "build:packages": "bun run --filter '@printr/mcp' --filter '@printr/cli' build",
    "dev": "bun run --cwd packages/cli dev",
    "dev:mcp": "bun run --cwd packages/mcp dev",
    "start": "bun run --cwd packages/cli start",
    "start:mcp": "bun run --cwd packages/mcp start",
    "inspect": "bun run --cwd packages/mcp inspect",
    "test": "bun run --filter '*' test",
    "test:all": "bun run --filter '*' test:all",
    "test:coverage": "bun run build:sdk && bun run --filter '@printr/mcp' --filter '@printr/cli' test --coverage",
    "test:e2e": "bun run build:sdk && bun run --cwd packages/mcp test:e2e",
    "typecheck": "bun run build:sdk && bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun typecheck && bun lint && bun test",
    "examples:test": "bun run --cwd examples/sdk-basic test && bun run --cwd examples/mcp-client test",
    "generate:api": "bash scripts/generate-api.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.9",
    "minimatch": "^10.2.4"
  },
  "overrides": {
    "minimatch": "^10.2.4"
  }
}
